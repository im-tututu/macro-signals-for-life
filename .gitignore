# Environment / secrets
# =========================
.env
.env.*
!.env.example

# Google service account / credentials
*service_account*.json
*service-account*.json
*credentials*.json
token.json
secrets.json

# =========================
# Local database / runtime data
# =========================
py/data/db.sqlite*
py/data/*.sqlite
py/data/*.sqlite3
py/data/logs/
py/data/exports/
py/data/snapshots/
py/data/tmp/
py/data/cache/

# keep folder structure if needed
!py/data/.gitkeep
!py/data/logs/.gitkeep
!py/data/exports/.gitkeep
!py/data/snapshots/.gitkeep

# =========================
# Python local outputs
# =========================
*.log
*.tmp
*.bak

# =========================
# Tests / local artifacts
# =========================
.pyre/
.tox/
.nox/

# =========================
# Node / frontend (future-proof, harmless if unused)
