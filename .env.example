# =========================================================
# macro-signals-for-life 本地环境变量模板
# 复制为 .env 后，再填入你自己的本地配置。
# 不要把真实密钥写进这个示例文件。
# =========================================================

# -----------------------------------------------------------------
# 核心路径
# -----------------------------------------------------------------
# SQLite 主数据库路径
DB_PATH=runtime/db/app.sqlite

# init_db.py 使用的初始化 SQL
INIT_SQL_PATH=py/sql/0001_init.sql

# 导入脚本默认工作簿路径
WORKBOOK_PATH=tools/local/宏观观察.xlsx

# -----------------------------------------------------------------
# Google Sheets / Google API
# -----------------------------------------------------------------
# Google service account JSON 文件路径
GOOGLE_APPLICATION_CREDENTIALS=tools/local/google/service-account.json

# 目标 Spreadsheet ID
GOOGLE_SPREADSHEET_ID=

# 导出到 Google Sheets 时可选的工作表前缀
GOOGLE_WORKSHEET_PREFIX=验证_

# -----------------------------------------------------------------
# GAS 部署
# -----------------------------------------------------------------
# Apps Script 项目 ID
GAS_SCRIPT_ID=

# 若希望 tools/local/set_github_secrets_from_env.sh 一并同步 CLASPRC_JSON，
# 可把 ~/.clasprc.json 压成一行后填在这里。
CLASPRC_JSON=

# -----------------------------------------------------------------
# 导入 / 导出行为
# -----------------------------------------------------------------
# 每张表默认导出行数上限；留空表示导出全部
EXPORT_LIMIT_PER_TABLE=

# 导出全部 raw_* 表时，是否包含空表
EXPORT_INCLUDE_EMPTY=0

# -----------------------------------------------------------------
# 日志与通知
# -----------------------------------------------------------------
LOG_LEVEL=INFO

# Bark 通知
BARK_BASE_URL=
BARK_DEVICE_KEY=

# -----------------------------------------------------------------
# 数据源 API
# -----------------------------------------------------------------
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------
# Jisilu ETF / Cookie 自动续期
# -----------------------------------------------------------------
# 可直接填现成 Cookie；若留空，则只能依赖 refresh webhook 自动续期
JISILU_COOKIE=

# 请求头中的 User-Agent
JISILU_USER_AGENT=Mozilla/5.0

# 检测到“游客仅显示前 20 条”时用于自动刷新 Cookie 的 webhook
JISILU_REFRESH_URL=http://127.0.0.1:8787/refresh/jisilu-cookie
JISILU_REFRESH_TOKEN=replace-with-a-long-random-token

# webhook 登录凭证
JISILU_USERNAME=
JISILU_PASSWORD=

# webhook 服务监听配置
JISILU_WEBHOOK_HOST=127.0.0.1
JISILU_WEBHOOK_PORT=8787
JISILU_WEBHOOK_TOKEN=replace-with-a-long-random-token
JISILU_HEADLESS=1
JISILU_NAV_TIMEOUT_MS=30000
JISILU_POST_LOGIN_WAIT_MS=2500
JISILU_ARTIFACT_DIR=runtime/tmp/jisilu_webhook
JISILU_MANUAL_LOGIN_TIMEOUT_MS=180000

# -----------------------------------------------------------------
# HTTP / 时区
# -----------------------------------------------------------------
HTTP_TIMEOUT_SECONDS=30
HTTP_RETRY_COUNT=3
HTTP_RETRY_SLEEP_SECONDS=1.2
TZ=Asia/Shanghai

# -----------------------------------------------------------------
# LLM 路由
# -----------------------------------------------------------------
LLM_PROVIDER=mimo
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-pro

# 指标快照分析参数
ANALYZE_MAX_METRICS=120
ANALYZE_TEMPERATURE=0.2
ANALYZE_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------
# 远端部署 / 同步
# -----------------------------------------------------------------
SERVER_HOST=
SERVER_PORT=22
SERVER_USER=
SERVER_APP_DIR=
