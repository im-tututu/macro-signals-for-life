# =========================================================
# macro-signals-for-life 本地环境变量模板
# 复制为 .env 后，再填入你自己的本地配置。
# 不要把真实密钥写进这个示例文件。
# =========================================================

# -----------------------------------------------------------------
# 核心路径
# -----------------------------------------------------------------
# Python 侧主配置入口。
# 当前 Python 代码优先读取这些变量名，MSFL_* 仅作为兼容别名保留。

# SQLite 路径，可填绝对路径或仓库相对路径
DB_PATH=py/data/db.sqlite

# init_db.py 使用的初始化 SQL
INIT_SQL_PATH=py/sql/0001_init.sql

# 导入脚本默认使用的工作簿路径，可留空
WORKBOOK_PATH=宏观观察.xlsx

# -----------------------------------------------------------------
# Google Sheets / Google API
# -----------------------------------------------------------------
# 建议把 service account JSON 放在仓库外，例如：
#   ~/.config/macro-signals/google/service-account.json
# 然后在这里填写路径，或通过环境变量导出 GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# 目标 Spreadsheet ID（即 Google Sheets 链接里的长 ID）
GOOGLE_SPREADSHEET_ID=

# 校验导出时可选的默认工作表前缀
GOOGLE_WORKSHEET_PREFIX=验证_

# -----------------------------------------------------------------
# 导入 / 导出行为
# -----------------------------------------------------------------
# 每张表默认导出行数上限；留空表示导出全部
EXPORT_LIMIT_PER_TABLE=

# 导出全部 raw_* 表时，是否包含空表
# 可填示例：0 / 1 / true / false
EXPORT_INCLUDE_EMPTY=0

# -----------------------------------------------------------------
# 日志
# -----------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------
# Remote server sync / deploy (for tools/sync_remote.sh and GitHub secret sync)
# -----------------------------------------------------------------
SERVER_HOST=
SERVER_PORT=22
SERVER_USER=
SERVER_APP_DIR=

# -----------------------------------------------------------------
# Jisilu ETF / Cookie Refresh
# -----------------------------------------------------------------
# Python ETF 抓取使用的现成 Cookie；若留空，则只能依赖 refresh webhook 自动续期
JISILU_COOKIE=

# Jisilu 请求头里的 User-Agent
JISILU_USER_AGENT=Mozilla/5.0

# 当 Python / GAS 检测到“游客仅显示前 20 条”时，会调用这个 webhook 获取新 Cookie
JISILU_REFRESH_URL=http://127.0.0.1:8787/refresh/jisilu-cookie
JISILU_REFRESH_TOKEN=replace-with-a-long-random-token

# webhook 服务本身使用的登录凭证
JISILU_USERNAME=
JISILU_PASSWORD=

# webhook 服务监听地址
JISILU_WEBHOOK_HOST=127.0.0.1
JISILU_WEBHOOK_PORT=8787
JISILU_WEBHOOK_TOKEN=replace-with-a-long-random-token
JISILU_HEADLESS=1
JISILU_NAV_TIMEOUT_MS=30000
JISILU_POST_LOGIN_WAIT_MS=2500
JISILU_ARTIFACT_DIR=py/data/tmp/jisilu_webhook
JISILU_MANUAL_LOGIN_TIMEOUT_MS=180000

# -----------------------------------------------------------------
# 可选通知占位（后续使用）
# 暂时不需要时请保持为空
# -----------------------------------------------------------------
BARK_BASE_URL=
BARK_DEVICE_KEY=

# -----------------------------------------------------------------
# Xiaomi MiMo
# -----------------------------------------------------------------
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-pro

# -----------------------------------------------------------------
# Unified LLM Router (optional, recommended)
# -----------------------------------------------------------------
# 支持值：mimo / deepseek
LLM_PROVIDER=mimo
# 若填写，会覆盖 provider 专属 key（MIMO_API_KEY / DEEPSEEK_API_KEY）
LLM_API_KEY=
# 若填写，会覆盖 provider 专属 base_url（MIMO_BASE_URL / DEEPSEEK_BASE_URL）
LLM_BASE_URL=
# 若填写，会覆盖 provider 专属 model（MIMO_MODEL / DEEPSEEK_MODEL）
LLM_MODEL=

# -----------------------------------------------------------------
# DeepSeek
# -----------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------
# Snapshot analysis tuning
# -----------------------------------------------------------------
ANALYZE_MAX_METRICS=120
ANALYZE_TEMPERATURE=0.2
ANALYZE_TIMEOUT_SECONDS=60
