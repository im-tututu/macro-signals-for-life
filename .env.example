# =========================================================
# macro-signals-for-life 本地环境变量模板
# 复制为 .env 后，再填入你自己的本地配置。
# 不要把真实密钥写进这个示例文件。
# =========================================================

# -----------------------------------------------------------------
# 核心路径
# -----------------------------------------------------------------
# Python 侧主配置入口。
# 当前 Python 代码优先读取这些变量名，MSFL_* 仅作为兼容别名保留。

# SQLite 路径，可填绝对路径或仓库相对路径
DB_PATH=py/data/db.sqlite

# init_db.py 使用的初始化 SQL
INIT_SQL_PATH=py/sql/0001_init.sql

# 导入脚本默认使用的工作簿路径，可留空
WORKBOOK_PATH=宏观观察.xlsx

# -----------------------------------------------------------------
# Google Sheets / Google API
# -----------------------------------------------------------------
# 建议把 service account JSON 放在仓库外，例如：
#   ~/.config/macro-signals/google/service-account.json
# 然后在这里填写路径，或通过环境变量导出 GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# 目标 Spreadsheet ID（即 Google Sheets 链接里的长 ID）
GOOGLE_SPREADSHEET_ID=

# 校验导出时可选的默认工作表前缀
GOOGLE_WORKSHEET_PREFIX=验证_

# -----------------------------------------------------------------
# 导入 / 导出行为
# -----------------------------------------------------------------
# 每张表默认导出行数上限；留空表示导出全部
EXPORT_LIMIT_PER_TABLE=

# 导出全部 raw_* 表时，是否包含空表
# 可填示例：0 / 1 / true / false
EXPORT_INCLUDE_EMPTY=0

# -----------------------------------------------------------------
# 日志
# -----------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------
# 可选通知占位（后续使用）
# 暂时不需要时请保持为空
# -----------------------------------------------------------------
BARK_BASE_URL=
BARK_DEVICE_KEY=
