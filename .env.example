# =========================================================
# Local environment template for macro-signals-for-life
# Copy to .env and fill in your own local values.
# Do not put real secrets in this file.
# =========================================================

# -----------------------------------------------------------------
# Core paths
# -----------------------------------------------------------------
# Absolute or repo-relative SQLite path
DB_PATH=py/data/db.sqlite

# Init SQL used by init_db.py
INIT_SQL_PATH=py/sql/0001_init_import_first.sql

# Optional default workbook path for import scripts
WORKBOOK_PATH=宏观观察.xlsx

# -----------------------------------------------------------------
# Google Sheets / Google API
# -----------------------------------------------------------------
# Recommended: store the service account JSON OUTSIDE the repo,
# for example:
#   ~/.config/macro-signals/google/service-account.json
# Then point to it here or export GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Target spreadsheet ID (the long ID in the Google Sheets URL)
GOOGLE_SPREADSHEET_ID=

# Optional default worksheet prefix for validation exports
GOOGLE_WORKSHEET_PREFIX=验证_

# -----------------------------------------------------------------
# Import / export behavior
# -----------------------------------------------------------------
# Default export row cap per table; leave empty for all rows
EXPORT_LIMIT_PER_TABLE=

# Include empty raw tables when exporting all raw_* tables
# Accepted examples: 0 / 1 / true / false
EXPORT_INCLUDE_EMPTY=0

# -----------------------------------------------------------------
# Logging
# -----------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------
# Optional notification placeholders (future use)
# Keep blank until you really need them
# -----------------------------------------------------------------
BARK_BASE_URL=
BARK_DEVICE_KEY=
